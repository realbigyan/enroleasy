// EnrolEasy — multi-tenant B2B SaaS schema
// Consultancy CRM + Nepal-compliant accounting platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// TENANCY & IDENTITY
// Every record in the CRM domain is scoped to an Organization
// (the consultancy that pays for EnrolEasy).
// ─────────────────────────────────────────────

enum Role {
  OWNER                 // consultancy account owner (billing, org settings)
  ADMIN                 // full CRM + accounting management
  ADMIN_ASSIST          // front-office: students, documents, invoices/receipts
  COUNSELOR             // manages leads/students/applications, no billing
  TRAINER               // legacy role, no longer tied to an active feature
  EXAMINER              // legacy role, no longer tied to an active feature
  CONTENT_MANAGER       // legacy role, no longer tied to an active feature
  DOCUMENTATION_OFFICER // handles visa/application paperwork
  STUDENT               // legacy role, no longer tied to an active feature
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  SCALE
}

enum SubscriptionStatus {
  PENDING_APPROVAL // new signup, awaiting a superadmin to approve and start the trial
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logoUrl       String?
  country       String?
  // Accounting: how this org bills for tax purposes. VAT_REGISTERED charges
  // 13% VAT on invoices; PAN_ONLY does not. Drives TDS rate selection on
  // Expense records too (1.5% w/ VAT invoice vs 15% on a PAN-only bill).
  taxRegistrationType TaxRegistrationType?
  panVatNumber        String?
  // Secret token for the generic lead-intake webhook (Zapier/Make etc.) —
  // distinct from `slug`, which is public/guessable. Generated on first use
  // via the Integrations settings page, rotatable at any time.
  leadWebhookToken String? @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  leads         Lead[]
  students      Student[]
  applications  Application[]
  tasks         Task[]
  notes         Note[]
  destinations  Destination[]
  subscription  Subscription?
  partners      Partner[]
  invoicers     Invoicer[]
  invoices      Invoice[]
  documents     Document[]
  activityLogs  ActivityLog[]
  auditLogs     AuditLog[]
  institutions  Institution[]
  notifications Notification[]
  metaIntegration MetaIntegration?

  // Accounting domain
  accounts      Account[]
  journalEntries JournalEntry[]
  vendors        Vendor[]
  expenses       Expense[]
  bankAccounts   BankAccount[]
  fixedAssets    FixedAsset[]
  employees      Employee[]

  @@map("organizations")
}

model Subscription {
  id                String             @id @default(cuid())
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId    String             @unique
  plan              SubscriptionPlan   @default(STARTER)
  status            SubscriptionStatus @default(TRIALING)
  seats             Int                @default(5)
  trialEndsAt       DateTime?
  currentPeriodEnd  DateTime?
  stripeCustomerId  String?
  stripeSubId       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("subscriptions")
}

model User {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  name           String
  email          String
  passwordHash   String
  role           Role         @default(COUNSELOR)
  avatarUrl      String?
  isActive       Boolean      @default(true)
  isSuperAdmin   Boolean      @default(false) // platform-level: can manage the shared global institution catalog
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignedLeads       Lead[]        @relation("AssignedCounselor")
  assignedTasks       Task[]        @relation("AssignedTo")
  notes               Note[]
  studentProfile      Student?      @relation("StudentUser")
  uploadedDocuments    Document[]    @relation("UploadedBy")
  activityLogs         ActivityLog[] @relation("ActivityAuthor")
  auditLogs            AuditLog[]    @relation("AuditActor")
  passwordResetTokens  PasswordResetToken[]
  notifications        Notification[]
  assignedApplications Application[] @relation("AssignedDocOfficer")
  employeeProfiles     Employee[]

  @@unique([organizationId, email])
  @@map("users")
}

// Single-use tokens for the forgot-password flow. We store a hash of the
// token (never the raw value) so a leaked DB row can't be replayed directly.
model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// PARTNERS — referral agents, B2B application partners, exam bodies
// ─────────────────────────────────────────────

enum PartnerType {
  REFERRAL
  B2B_APPLICATION
  EXAM_BODY
}

model Partner {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  name           String
  type           PartnerType  @default(REFERRAL)
  contactEmail   String?
  contactPhone   String?
  commissionPct  Float?       // default commission rate for referrals through this partner
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  referredLeads    Lead[]
  referredStudents Student[]
  invoices         Invoice[]

  @@index([organizationId])
  @@map("partners")
}

// ─────────────────────────────────────────────
// CRM DOMAIN
// ─────────────────────────────────────────────

enum LeadStage {
  NEW
  CONTACTED
  TRIAL_BOOKED
  TRIAL_DONE
  QUALIFIED
  COUNSELING
  APPLICATION_STARTED
  OFFER_RECEIVED
  VISA_STAGE
  ENROLLED
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  WALK_IN
  SOCIAL_MEDIA
  EVENT
  PARTNER_AGENT
  META_ADS   // via the native Meta Lead Ads integration or the generic webhook
  CSV_IMPORT // bulk-uploaded (e.g. exported from Meta Ads Manager)
  OTHER
}

model Lead {
  id                  String       @id @default(cuid())
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId      String
  fullName            String
  email               String?
  phone               String?
  source              LeadSource   @default(WEBSITE)
  stage               LeadStage    @default(NEW)
  interestedCountry   String?
  targetIntake        String?      // e.g. "Fall 2026"
  targetScore         String?      // e.g. "Band 7.0"
  tags                String[]     @default([])
  assignedCounselor   User?        @relation("AssignedCounselor", fields: [assignedCounselorId], references: [id])
  assignedCounselorId String?
  referredBy          Partner?     @relation(fields: [referredByPartnerId], references: [id])
  referredByPartnerId String?
  convertedStudent    Student?
  tasks               Task[]
  notes               Note[]
  activityLogs        ActivityLog[]
  lastActivityAt      DateTime?
  archivedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  // External reference used to de-duplicate leads created by an automated
  // intake path (the generic webhook, the native Meta integration, or a
  // repeated CSV upload) — e.g. Meta's leadgen_id, or a Zapier-supplied id.
  // Null for leads entered manually or through the public booking form.
  externalId          String?

  @@index([organizationId, stage])
  @@unique([organizationId, externalId])
  @@map("leads")
}

// A consultancy's connected Facebook Page for the native Meta Lead Ads
// integration (option 2 of the lead-intake feature). One per organization.
// `pageAccessToken` is a long-lived Page token from the OAuth connect flow —
// production hardening note: this should be encrypted at rest (e.g. via a
// KMS-backed field) rather than stored as plain text; flagged here rather
// than silently shipped as-is.
enum MetaIntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR // token expired/revoked, or Graph API calls started failing
}

model MetaIntegration {
  id               String                @id @default(cuid())
  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String                @unique
  pageId           String
  pageName         String
  pageAccessToken  String
  subscribedFormIds String[]             @default([]) // empty = sync leads from every form on the page
  status           MetaIntegrationStatus @default(CONNECTED)
  connectedByUserId String?
  lastLeadAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@map("meta_integrations")
}

model Destination {
  id             String        @id @default(cuid())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  country        String
  university     String
  course         String
  intake         String
  tuitionFeeUsd  Int?
  applications   Application[]
  createdAt      DateTime      @default(now())

  @@map("destinations")
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  OFFER_CONDITIONAL
  OFFER_UNCONDITIONAL
  DEPOSIT_PAID
  VISA_APPLIED
  VISA_APPROVED
  REJECTED
  WITHDRAWN
}

// Manually-tracked, granular application stage kept by the Documentation
// Officer. Distinct from ApplicationStatus (a coarse system-wide status) —
// this mirrors the real-world offline process of dealing with universities
// and visa offices, which varies by destination country. OTHER + a free-text
// label covers countries with a different process.
enum ApplicationStage {
  WAITING_KEY_DOCUMENTS
  APPLICATION
  OFFER_RECEIVED
  OFFER_DENIED
  DOCUMENTATION
  WAITING_GS_APPROVAL
  GS_APPROVED
  GS_REJECTED
  WAITING_VISA_LODGEMENT
  VISA_LODGED
  VISA_GRANTED
  VISA_REFUSED
  LOST
  OTHER
}

model Application {
  id             String            @id @default(cuid())
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String
  destination    Destination       @relation(fields: [destinationId], references: [id])
  destinationId  String
  status         ApplicationStatus @default(DRAFT)
  requiredIelts  Float?
  requiredPte    Int?
  submittedAt    DateTime?
  decisionAt     DateTime?
  notes          Note[]
  activityLogs   ActivityLog[]
  // Manually-tracked stage (Documentation Officer). Nullable: not every
  // application has entered the manual tracking workflow yet.
  currentStage          ApplicationStage?
  currentStageOther     String?   // free-text label when currentStage = OTHER
  currentStageUpdatedAt DateTime?
  // Chosen by the counsellor (or whoever creates the application) from the
  // org's active Documentation Officers. Nullable: assignment is optional,
  // e.g. an org with no Documentation Officers registered yet.
  assignedDocOfficer   User?     @relation("AssignedDocOfficer", fields: [assignedDocOfficerId], references: [id])
  assignedDocOfficerId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, assignedDocOfficerId])
  @@map("applications")
}

model Student {
  id              String        @id @default(cuid())
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  fromLead        Lead?         @relation(fields: [fromLeadId], references: [id])
  fromLeadId      String?       @unique
  user            User?         @relation("StudentUser", fields: [userId], references: [id])
  userId          String?       @unique
  referredBy      Partner?      @relation(fields: [referredByPartnerId], references: [id])
  referredByPartnerId String?
  fullName        String
  email           String?
  phone           String?
  passportNo      String?
  passportExpiry  DateTime?
  countryOfBirth  String?
  currentCountry  String?
  dob             DateTime?
  tags            String[]      @default([])
  isChurned       Boolean       @default(false)
  // Academic profile used for course-eligibility matching
  academicGpaPercent Float?
  gapYears           Int?
  englishTestType    StudentLanguageStatus?
  englishScore       Float?
  lastActivityAt  DateTime?
  archivedAt      DateTime?
  applications    Application[]
  tasks           Task[]
  notes           Note[]
  educationRecords  EducationRecord[]
  emergencyContacts EmergencyContact[]
  examBookings      ExamBooking[]
  documents         Document[]
  invoices          Invoice[]
  activityLogs      ActivityLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("students")
}

model EducationRecord {
  id             String   @id @default(cuid())
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String
  institution    String
  qualification  String   // e.g. "Bachelor's Degree"
  fieldOfStudy   String?
  yearCompleted  Int?
  gpaOrPercentage String?
  createdAt      DateTime @default(now())

  @@map("education_records")
}

enum EmergencyContactKind {
  PRIMARY
  SECONDARY
}

model EmergencyContact {
  id        String               @id @default(cuid())
  student   Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  kind      EmergencyContactKind
  name      String
  relation  String?
  phone     String?
  email     String?

  @@unique([studentId, kind])
  @@map("emergency_contacts")
}

enum ExamBookingStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

model ExamBooking {
  id           String            @id @default(cuid())
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  testType     TestType
  examDate     DateTime
  center       String?
  status       ExamBookingStatus @default(BOOKED)
  resultDate   DateTime?
  resultScore  Float?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([studentId])
  @@map("exam_bookings")
}

enum DocumentType {
  // Legacy/general types, kept for backward compatibility with existing docs
  PASSPORT
  TRANSCRIPT
  VISA
  OFFER_LETTER
  CERTIFICATE
  OTHER

  // Personal
  PERSONAL_ID
  PERSONAL_ACADEMIC
  PERSONAL_ENGLISH
  PERSONAL_CV
  PERSONAL_WORK_EXPERIENCE

  // Spouse
  SPOUSE_ID
  SPOUSE_ACADEMIC
  SPOUSE_ENGLISH
  SPOUSE_CV
  SPOUSE_WORK_EXPERIENCE
  SPOUSE_MARRIAGE_CERTIFICATE

  // Sponsors
  SPONSOR_ID
  SPONSOR_RELATIONSHIP
  SPONSOR_PROOF_OF_INCOME

  // Bank
  BANK_LOAN
  BANK_BALANCE_CERTIFICATE
}

model Document {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  student        Student?     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String?
  type           DocumentType @default(OTHER)
  fileName       String
  url            String       // Cloudinary secure_url
  publicId       String?      // Cloudinary public_id, for deletion
  uploadedBy     User?        @relation("UploadedBy", fields: [uploadedById], references: [id])
  uploadedById   String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, studentId])
  @@map("documents")
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

model Task {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  title          String
  dueAt          DateTime?
  status         TaskStatus   @default(OPEN)
  assignedTo     User?        @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId   String?
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId         String?
  student        Student?     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("tasks")
}

model Note {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  body           String
  author         User         @relation(fields: [authorId], references: [id])
  authorId       String
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId         String?
  student        Student?     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String?
  application    Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId  String?
  createdAt      DateTime     @default(now())

  @@map("notes")
}

// Unified interaction log shown as an "Activity Timeline" on lead/student profiles.
// Distinct from Note (a written note) — this also captures system events like
// stage changes, calls logged, emails sent, etc.
model ActivityLog {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId         String?
  student        Student?     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String?
  application    Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId  String?
  author         User?        @relation("ActivityAuthor", fields: [authorId], references: [id])
  authorId       String?
  type           String       // e.g. "call", "email", "meeting", "stage_change", "note"
  description    String
  createdAt      DateTime     @default(now())

  @@index([organizationId, leadId])
  @@index([organizationId, studentId])
  @@index([organizationId, applicationId])
  @@map("activity_logs")
}

// Tracks admin actions with before/after snapshots for compliance/accountability.
model AuditLog {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  actor          User?        @relation("AuditActor", fields: [actorId], references: [id])
  actorId        String?
  action         String       // e.g. "update", "delete", "archive"
  entityType     String       // e.g. "Student", "Lead", "Invoice"
  entityId       String
  beforeJson     Json?
  afterJson      Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, entityType, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// BILLING & INVOICING
// Supports multiple legal "invoicer" entities issuing invoices to either
// students or partners (e.g. commission invoices).
// ─────────────────────────────────────────────

enum TaxIdType {
  PAN
  VAT
}

model Invoicer {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  name           String
  invoicePrefix  String       // e.g. "UPS" -> UPS-2026-0001
  receiptPrefix  String?
  logoUrl        String?
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  // Branding/legal details rendered on the printable invoice/receipt
  addressLine1     String?
  addressLine2     String?
  taxIdType        TaxIdType?
  taxIdNumber      String?
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  bankBranch        String?
  bankSwift         String?
  qrCodeUrl         String?   // e.g. payment QR shown on the receipt
  footerWebsite     String?
  footerPhone       String?
  footerEmail       String?
  createdAt      DateTime     @default(now())

  invoices       Invoice[]

  @@index([organizationId])
  @@map("invoicers")
}

enum BilledToType {
  STUDENT
  PARTNER
}

enum FeeType {
  MANUAL
  MEMBERSHIP
  COMMISSION
}

enum InvoiceStatus {
  UNPAID
  PAID
  VOID
}

model Invoice {
  id             String        @id @default(cuid())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  invoicer       Invoicer      @relation(fields: [invoicerId], references: [id])
  invoicerId     String
  invoiceNumber  String        // generated as `${invoicer.invoicePrefix}-${year}-${seq}`
  billedToType   BilledToType
  student        Student?      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String?
  partner        Partner?      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId      String?
  feeType        FeeType       @default(MANUAL)
  description    String?
  amount         Float
  currency       String        @default("USD")
  status         InvoiceStatus @default(UNPAID)
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@map("invoices")
}

// ─────────────────────────────────────────────
// Shared test-type enum, used by ExamBooking (tracking a student's real,
// externally-sat IELTS/PTE/Duolingo exam) and by the institution/course
// catalog's language entry requirements below.
// ─────────────────────────────────────────────

enum TestType {
  IELTS
  PTE
  DUOLINGO
}

// ─────────────────────────────────────────────
// INSTITUTION & COURSE CATALOG
// Manually-curated catalog of institutions and their courses, used to run
// eligibility-based course search against a student's academic profile.
// Institution.organizationId is nullable: null = shared/global catalog
// (managed by a platform superadmin), non-null = private to that consultancy.
// ─────────────────────────────────────────────

enum LanguageTestType {
  IELTS
  PTE
  DUOLINGO
  MOI          // Medium of Instruction certificate in lieu of a test
  NOT_REQUIRED
}

enum StudentLanguageStatus {
  IELTS
  PTE
  DUOLINGO
  MOI
  NONE
}

enum InstitutionType {
  PUBLIC_UNIVERSITY
  PRIVATE_UNIVERSITY
  VET_COLLEGE
  PRIVATE_COLLEGE
  POLYTECHNIC
}

model Institution {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?       // null = shared global catalog
  name           String
  country        String
  locations      String[]      @default([]) // campuses/cities within the country
  type           InstitutionType?
  website        String?
  logoUrl        String?
  introduction   String?       // "university intro" description
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  courses        Course[]
  rankings       InstitutionRanking[]

  @@index([organizationId, country])
  @@map("institutions")
}

// A flexible list of rankings so an institution can carry several at once
// (e.g. "Global" via QS, "Country" via a national ranking body, plus any
// other scope a counsellor wants to record) rather than one fixed rank.
model InstitutionRanking {
  id            String      @id @default(cuid())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  institutionId String
  scope         String      // free text, e.g. "Global", "Country", "QS Asia"
  rank          Int
  source        String      // e.g. "QS World University Rankings 2026"
  createdAt     DateTime    @default(now())

  @@index([institutionId])
  @@map("institution_rankings")
}

model Course {
  id                String           @id @default(cuid())
  institution       Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  institutionId     String
  name              String
  level             String?          // e.g. "Undergraduate", "Postgraduate", "Diploma"
  durationMonths    Int?
  feeAmount         Float?
  feeCurrency       String           @default("USD")
  careerOutcomes    String?          // career prospects / outcomes description
  description       String?          // course description
  // Entry requirements
  minGpaPercent     Float?
  maxGapYears       Int?
  languageTestType  LanguageTestType @default(NOT_REQUIRED)
  languageMinScore  Float?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([institutionId])
  @@map("courses")
}

// In-app alerts for role-targeted events, e.g. "a counsellor created an
// application" pinged to Documentation Officers. Read state is per-recipient.
model Notification {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  recipient      User         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId    String
  type           String       // e.g. "application_created"
  title          String
  body           String?
  link           String?      // e.g. /dashboard/students/{id}
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([organizationId, recipientId, read])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// ACCOUNTING DOMAIN — Nepal-compliant double-entry books
// Fiscal periods use the Nepali (Bikram Sambat) fiscal year, Shrawan 1 to
// Ashadh-end, labelled e.g. "2082/83". See src/lib/accounting/fiscal-year.ts.
// ─────────────────────────────────────────────

enum TaxRegistrationType {
  VAT_REGISTERED
  PAN_ONLY
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalSourceType {
  MANUAL
  INVOICE
  INVOICE_PAYMENT
  EXPENSE
  PAYROLL
  DEPRECIATION
  BANK
  OPENING_BALANCE
  FIXED_ASSET
}

enum BankAccountKind {
  BANK
  CASH
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DIMINISHING_BALANCE
}

// Chart of accounts. Every org gets a default Nepal-oriented set seeded on
// first use (see src/lib/accounting/seed-chart-of-accounts.ts), fully
// editable/extendable afterwards. Hierarchical via parent for subtotals.
model Account {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  code           String       // e.g. "1000", "4100" — sortable, editable
  name           String
  type           AccountType
  parent         Account?     @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  parentId       String?
  children       Account[]    @relation("AccountHierarchy")
  isSystem       Boolean      @default(false) // seeded default account; UI discourages delete, doesn't block it
  isActive       Boolean      @default(true)
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  journalLines          JournalLine[]
  expenses              Expense[]         @relation("ExpenseCategoryAccount")
  expensePayments       Expense[]         @relation("ExpensePaymentAccount")
  fixedAssets           FixedAsset[]      @relation("FixedAssetAccount")
  fixedAssetPayments    FixedAsset[]      @relation("FixedAssetPaymentAccount")
  bankAccount           BankAccount?
  bankTransactionsAsCounter BankTransaction[]
  payslipPayments       Payslip[]         @relation("PayslipPaymentAccount")

  @@unique([organizationId, code])
  @@index([organizationId, type])
  @@map("accounts")
}

// A balanced double-entry transaction. Sum(debit) must equal sum(credit)
// across its lines — enforced in the API layer, not the DB.
model JournalEntry {
  id             String            @id @default(cuid())
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  date           DateTime
  fiscalYear     String            // Nepali BS fiscal year label, e.g. "2082/83"
  reference      String?           // e.g. invoice #, cheque #
  description    String
  sourceType     JournalSourceType @default(MANUAL)
  sourceId       String?           // id of the Invoice/Expense/Payslip/etc. that generated this, if any
  createdById    String
  createdAt      DateTime          @default(now())

  lines          JournalLine[]

  @@index([organizationId, fiscalYear])
  @@index([organizationId, date])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId String
  account        Account      @relation(fields: [accountId], references: [id])
  accountId      String
  debit          Float        @default(0)
  credit         Float        @default(0)
  memo           String?

  @@index([accountId])
  @@map("journal_lines")
}

// Vendors / suppliers the org pays — needed to issue TDS withholding certificates.
model Vendor {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  name           String
  panNumber      String?
  address        String?
  email          String?
  phone          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  expenses       Expense[]

  @@index([organizationId])
  @@map("vendors")
}

// A business expense/purchase. Auto-posts a journal entry (debit expense
// account, credit cash/bank) and computes TDS to withhold per the Income
// Tax Act 2058 secs. 87-92 rates (e.g. 1.5% on a VAT-invoiced service,
// 15% on a PAN-only service bill, ~10% on rent).
model Expense {
  id              String           @id @default(cuid())
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  vendor          Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorId        String?
  account         Account          @relation("ExpenseCategoryAccount", fields: [accountId], references: [id])
  accountId       String
  // GL account credited for the payment (e.g. "Cash in Hand", "Bank Accounts",
  // or "Accounts Payable" if paid on credit) — independent of the BankAccount
  // reconciliation module below, which is a separate future addition.
  paymentAccount   Account          @relation("ExpensePaymentAccount", fields: [paymentAccountId], references: [id])
  paymentAccountId String
  date            DateTime
  fiscalYear      String
  description     String
  amount          Float            // gross amount before VAT
  vatAmount       Float            @default(0)
  hasVatInvoice   Boolean          @default(false) // affects TDS rate selection
  tdsRate         Float            @default(0)     // percentage, e.g. 1.5, 15, 10
  tdsAmount       Float            @default(0)
  bankAccount     BankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  bankAccountId   String?
  attachmentUrl   String?
  createdAt       DateTime         @default(now())

  @@index([organizationId, fiscalYear])
  @@map("expenses")
}

// Bank & cash accounts, plus their transaction ledger for reconciliation.
// Each BankAccount is backed 1:1 by a GL Account (auto-created as a child of
// "1010 Cash in Hand" or "1020 Bank Accounts") so its balance is always part
// of the real double-entry books, not a separate shadow ledger.
model BankAccount {
  id             String          @id @default(cuid())
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  account        Account         @relation(fields: [accountId], references: [id])
  accountId      String          @unique
  name           String          // e.g. "NIC Asia - Operating", "Petty Cash"
  kind           BankAccountKind @default(BANK)
  accountNumber  String?
  bankName       String?
  currency       String          @default("NPR")
  openingBalance Float           @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())

  transactions   BankTransaction[]
  expenses       Expense[]

  @@index([organizationId])
  @@map("bank_accounts")
}

model BankTransaction {
  id              String      @id @default(cuid())
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  bankAccountId   String
  // The other side of the double entry, e.g. an Income account for a
  // deposit received directly, Equity for an owner's capital injection,
  // Liability for loan proceeds, etc.
  counterAccount  Account     @relation(fields: [counterAccountId], references: [id])
  counterAccountId String
  date            DateTime
  description     String
  amount          Float       // positive = deposit/inflow, negative = withdrawal/outflow
  reconciled      Boolean     @default(false)
  createdAt       DateTime    @default(now())

  @@index([bankAccountId])
  @@map("bank_transactions")
}

// Fixed assets + straight-line/diminishing-balance depreciation schedule,
// one DepreciationEntry generated per Nepali fiscal year.
model FixedAsset {
  id                  String              @id @default(cuid())
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId      String
  account             Account             @relation("FixedAssetAccount", fields: [accountId], references: [id])
  accountId           String
  // GL account credited for the purchase (cash/bank/AP), same pattern as
  // Expense.paymentAccountId.
  paymentAccount      Account             @relation("FixedAssetPaymentAccount", fields: [paymentAccountId], references: [id])
  paymentAccountId    String
  name                String
  purchaseDate        DateTime
  cost                Float
  usefulLifeYears     Int
  salvageValue        Float               @default(0)
  method              DepreciationMethod  @default(STRAIGHT_LINE)
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())

  depreciationEntries DepreciationEntry[]

  @@index([organizationId])
  @@map("fixed_assets")
}

model DepreciationEntry {
  id           String     @id @default(cuid())
  fixedAsset   FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  fixedAssetId String
  fiscalYear   String
  amount       Float
  createdAt    DateTime   @default(now())

  @@unique([fixedAssetId, fiscalYear])
  @@map("depreciation_entries")
}

// Staff payroll — separate from the CRM `User` staff model since not every
// employee needs platform login access, and salary data is more sensitive.
model Employee {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId         String?      // optional link to their login account
  name           String
  panNumber      String?
  designation    String?
  basicSalary    Float
  allowances     Float        @default(0)
  ssfEnrolled    Boolean      @default(false) // Social Security Fund registered employee
  isActive       Boolean      @default(true)
  joinedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())

  payslips       Payslip[]

  @@index([organizationId])
  @@map("employees")
}

model Payslip {
  id             String    @id @default(cuid())
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     String
  organizationId String
  paymentAccount   Account   @relation("PayslipPaymentAccount", fields: [paymentAccountId], references: [id])
  paymentAccountId String
  month          Int       // 1-12, Nepali month (1 = Baishakh)
  fiscalYear     String
  grossPay       Float
  ssfEmployee    Float     @default(0) // 11% employee SSF contribution, if enrolled
  ssfEmployer    Float     @default(0) // 20% employer SSF contribution, if enrolled
  taxableIncome  Float
  tdsAmount      Float     @default(0)
  netPay         Float
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  @@unique([employeeId, fiscalYear, month])
  @@index([organizationId, fiscalYear])
  @@map("payslips")
}
